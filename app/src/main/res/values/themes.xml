<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.AnimaList" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/warna_bg_utama</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/warna_bg_utama</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="O_MR1">true</item>
    </style>

    <style name="Theme.AnimaList" parent="Base.Theme.AnimaList" />

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.AnimaList.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>

        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <item name="postSplashScreenTheme">@style/Theme.AnimaList</item>
    </style>
</resources>